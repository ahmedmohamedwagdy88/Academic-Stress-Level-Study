      <aliases enabled='yes' />
      <column caption='study enviroment compined' datatype='integer' name='[Calculation_74027976218693632]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL([Study Environment_Peaceful],[Study Environment_disrupted])' />
      </column>
      <column caption='Calculation1' datatype='real' name='[Calculation_74027976242458627]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Study Environment] = &quot;Peaceful&quot; THEN 1 ELSE 0 END) &#13;&#10;/ COUNT([Study Environment])' />
      </column>
      <column caption='acdmic ' datatype='integer' name='[Calculation_74027976243851268]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Academic pressure from your home] &gt;= 3 THEN 1 ELSE 0 END' />
